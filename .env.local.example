# Where the eSIM API runs. Local dev defaults to the Fastify
# server on :4000. In production this points at the Railway URL
# (e.g. https://api.esim.sinaitaxi.com).
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# Stripe publishable key (pk_test_… for dev, pk_live_… for prod).
# Pulled from the Sinai Taxi Stripe dashboard. Safe to expose to
# the client by definition — it can only START a payment intent,
# not confirm one.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
